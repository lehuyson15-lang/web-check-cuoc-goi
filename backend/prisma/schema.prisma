generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String              @id @default(uuid())
  name                    String
  email                   String              @unique
  password                String
  role                    Role                @default(USER)
  extensionVoip           String?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  address                 String?
  department              String?
  emergencyContact        String?
  gender                  String?
  joinDate                DateTime?           @default(now())
  phoneNumber             String?
  status                  String?             @default("online")
  targetCallsPerDay       Int?                @default(50)
  targetConversionsPerDay Int?                @default(5)
  avatar                  String?
  calls                   Call[]
  leads                   Lead[]
  notifications           Notification[]
  dispatchMemberships     DispatchMember[]
  dispatches              Dispatch[]

  @@map("users")
}

model Call {
  id                String              @id @default(uuid())
  userId            String
  customerPhone     String
  direction         CallDirection
  source            CallSource
  durationSeconds   Int
  calledAt          DateTime
  serviceType       String?
  result            CallResult          @default(PENDING)
  audioUrl          String?
  transcriptStatus  TranscriptStatus    @default(PENDING)
  notes             String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  customerName      String?
  numberType        String?
  gender            String?
  customerStatus    String?
  recallNotified30d Boolean             @default(false)
  recallNotified3d  Boolean             @default(false)
  recallNotified7d  Boolean             @default(false)
  tags              CallTag[]
  user              User                @relation(fields: [userId], references: [id])
  segments          TranscriptSegment[]

  @@map("calls")
}

model TranscriptSegment {
  id         String   @id @default(uuid())
  callId     String
  speaker    String
  startTime  Float
  endTime    Float
  text       String
  confidence Float?
  createdAt  DateTime @default(now())
  call       Call     @relation(fields: [callId], references: [id], onDelete: Cascade)

  @@map("transcript_segments")
}

model CallTag {
  id        String   @id @default(uuid())
  callId    String
  tagType   String
  tagValue  String
  createdAt DateTime @default(now())
  call      Call     @relation(fields: [callId], references: [id], onDelete: Cascade)

  @@map("call_tags")
}

model Lead {
  id            String   @id @default(uuid())
  customerPhone String
  customerName  String?
  assignedToId  String
  status        String   @default("NEW")
  assignedAt    DateTime @default(now())
  slaDeadline   DateTime
  slaNotified   Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  assignedTo    User     @relation(fields: [assignedToId], references: [id])

  @@map("leads")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model DispatchQueue {
  id           String           @id @default(uuid())
  name         String           @default("default")
  currentIndex Int              @default(0)
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  members      DispatchMember[]
  dispatches   Dispatch[]

  @@map("dispatch_queues")
}

model DispatchMember {
  id        String        @id @default(uuid())
  queueId   String
  userId    String
  sortOrder Int           @default(0)
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  queue     DispatchQueue @relation(fields: [queueId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id])

  @@unique([queueId, userId])
  @@map("dispatch_members")
}

model Dispatch {
  id            String        @id @default(uuid())
  queueId       String
  customerPhone String
  customerName  String?
  source        String?
  assignedToId  String
  status        String        @default("PENDING")
  note          String?
  slaMinutes    Int           @default(15)
  slaDeadline   DateTime
  assignedAt    DateTime      @default(now())
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  queue         DispatchQueue @relation(fields: [queueId], references: [id])
  assignedTo    User          @relation(fields: [assignedToId], references: [id])

  @@map("dispatches")
}

enum Role {
  ADMIN
  MANAGER
  USER
}

enum CallDirection {
  INBOUND
  OUTBOUND
}

enum CallSource {
  MANUAL
  VOIP
}

enum CallResult {
  CLOSED
  PENDING
  CALLBACK
  NO_ANSWER
}

enum TranscriptStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}
